{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernloom.dev/schemas/adapter_manifest.schema.json",
  "title": "Kernloom adapter manifest",
  "type": "object",
  "required": ["adapter_id", "adapter_version", "protocol_version", "status", "capabilities"],
  "properties": {
    "adapter_id": { "type": "string", "minLength": 1 },
    "adapter_version": { "type": "string", "minLength": 1 },
    "protocol_version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["stable", "planned", "experimental"] },
    "component_role": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability_id", "implementation_status"],
        "properties": {
          "capability_id": { "type": "string", "minLength": 1 },
          "implementation_status": { "enum": ["implemented", "planned", "experimental"] },
          "supported_actions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "implemented_granularities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "required_privileges": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "evidence_quality": { "type": "object", "additionalProperties": { "type": "string" } },
          "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal_id"],
        "properties": {
          "signal_id": { "type": "string", "minLength": 1 },
          "implementation_status": { "enum": ["implemented", "planned", "experimental"] }
        },
        "additionalProperties": false
      }
    },
    "raw_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal_id", "projectors"],
        "properties": {
          "signal_id": { "type": "string", "minLength": 1 },
          "projectors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    },
    "privileges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["privilege_id"],
        "properties": {
          "privilege_id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "context_requirements": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
